{
  "name": "stock-tracking-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "start": "bun server.ts",
    "dev": "bun --hot server.ts",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun build server.ts --target=bun --outdir=/tmp/stock-tracker-check"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
